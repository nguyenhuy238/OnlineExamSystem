@model ExamSystem.Web.Models.Admin.QuestionIndexViewModel
@{
    ViewData["Title"] = "Questions";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Questions</h1>
    <a asp-action="Create" asp-route-examId="@Model.ExamId" class="btn btn-primary">Create Question</a>
</div>

@if (TempData["Success"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}
@if (TempData["Error"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <select class="form-select" asp-for="ExamId" asp-items="Model.ExamOptions">
            <option value="">All Exams</option>
        </select>
    </div>
    <div class="col-md-8">
        <button type="submit" class="btn btn-outline-primary">Filter</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
        <tr>
            <th>Exam</th>
            <th>Question</th>
            <th>Answer</th>
            <th class="text-end">Actions</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var question in Model.Questions)
        {
            <tr>
                <td>@question.ExamTitle</td>
                <td>@question.Content</td>
                <td>@question.CorrectAnswer</td>
                <td class="text-end">
                    <a asp-action="Edit" asp-route-id="@question.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    <form asp-action="Delete" asp-route-id="@question.Id" asp-route-examId="@Model.ExamId" method="post" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this question?');">Delete</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
