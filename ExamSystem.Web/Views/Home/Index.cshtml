@{
    ViewData["Title"] = "Home Page";
    var fullName = Context.Session.GetString(SessionKeys.FullName);
    var role = Context.Session.GetString(SessionKeys.Role);
}

<div class="text-center">
    <h1 class="display-5">Welcome, @fullName</h1>
    <p class="lead">You are logged in with role: <strong>@role</strong>.</p>
</div>
