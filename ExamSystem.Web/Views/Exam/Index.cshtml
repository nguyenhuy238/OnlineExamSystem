@model IReadOnlyList<ExamSystem.Core.Models.Exam>
@{
    ViewData["Title"] = "Exams";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Exams</h1>
    <a asp-action="Create" class="btn btn-primary">Create Exam</a>
</div>

@if (TempData["Success"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}
@if (TempData["Error"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
        <tr>
            <th>Title</th>
            <th>Subject</th>
            <th>Duration</th>
            <th>Pass Score</th>
            <th>Status</th>
            <th class="text-end">Actions</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var exam in Model)
        {
            <tr>
                <td>@exam.Title</td>
                <td>@exam.Subject</td>
                <td>@exam.Duration min</td>
                <td>@exam.PassScore.ToString("0.##")</td>
                <td>
                    @if (exam.IsActive)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactive</span>
                    }
                </td>
                <td class="text-end">
                    <a asp-action="Edit" asp-route-id="@exam.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    <a asp-controller="Question" asp-action="Index" asp-route-examId="@exam.Id" class="btn btn-sm btn-outline-info">Questions</a>
                    <form asp-action="Delete" asp-route-id="@exam.Id" method="post" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this exam?');">Delete</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
