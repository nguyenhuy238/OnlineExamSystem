@model ExamSystem.Core.Models.DashboardStats
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Dashboard</h1>
    <div class="btn-group">
        <a asp-controller="Student" asp-action="Index" class="btn btn-outline-primary">Students</a>
        <a asp-controller="Exam" asp-action="Index" class="btn btn-outline-primary">Exams</a>
        <a asp-controller="Question" asp-action="Index" class="btn btn-outline-primary">Questions</a>
    </div>
</div>

@if (TempData["Error"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h2 class="h6 text-muted">Total Students</h2>
                <p class="display-6 mb-0">@Model.TotalStudents</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h2 class="h6 text-muted">Total Exams</h2>
                <p class="display-6 mb-0">@Model.TotalExams</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h2 class="h6 text-muted">Total Attempts</h2>
                <p class="display-6 mb-0">@Model.TotalAttempts</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h2 class="h6 text-muted">Pass Rate</h2>
                <p class="display-6 mb-0">@Model.PassRate.ToString("0.##")%</p>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h2 class="h6 text-muted">Average Score</h2>
                <p class="display-6 mb-0">@Model.AverageScore.ToString("0.##")</p>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h2 class="h6 text-muted">Top Students</h2>
                @if (Model.TopStudents.Count == 0)
                {
                    <p class="text-muted mb-0">No exam results yet.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                            <tr>
                                <th>Student</th>
                                <th>Avg Score</th>
                                <th>Total Exams</th>
                            </tr>
                            </thead>
                            <tbody>
                            @foreach (var item in Model.TopStudents)
                            {
                                <tr>
                                    <td>@item.FullName</td>
                                    <td>@item.AvgScore.ToString("0.##")</td>
                                    <td>@item.TotalExams</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm mt-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Realtime Submission Notifications</span>
        <span id="signalr-status" class="badge bg-secondary">Disconnected</span>
    </div>
    <div class="card-body">
        <ul id="submission-feed" class="list-group list-group-flush"></ul>
    </div>
</div>

@section Scripts {
    <script src="~/lib/signalr/dist/browser/signalr.min.js" asp-append-version="true"></script>
    <script>
        (() => {
            const statusBadge = document.getElementById("signalr-status");
            const feed = document.getElementById("submission-feed");
            let reconnectTimer = null;

            function setStatus(isConnected) {
                statusBadge.textContent = isConnected ? "Connected" : "Disconnected";
                statusBadge.classList.toggle("bg-success", isConnected);
                statusBadge.classList.toggle("bg-secondary", !isConnected);
            }

            function addFeedItem(text) {
                const item = document.createElement("li");
                item.className = "list-group-item";
                item.textContent = text;
                feed.prepend(item);

                while (feed.children.length > 20) {
                    feed.removeChild(feed.lastChild);
                }
            }

            function scheduleReconnect() {
                if (reconnectTimer !== null) {
                    return;
                }

                reconnectTimer = window.setTimeout(() => {
                    reconnectTimer = null;
                    connect();
                }, 3000);
            }

            if (!window.signalR) {
                addFeedItem("SignalR client script was not loaded.");
                setStatus(false);
                return;
            }

            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/examHub")
                .withAutomaticReconnect()
                .build();

            connection.on("StudentSubmitted", (studentName, examId, utcTime) => {
                const timestamp = new Date(utcTime).toLocaleString();
                addFeedItem(`${timestamp} - ${studentName} submitted Exam #${examId}`);
            });

            connection.on("StudentJoined", (studentName, examId) => {
                const timestamp = new Date().toLocaleString();
                addFeedItem(`${timestamp} - ${studentName} joined Exam #${examId}`);
            });

            async function joinAdminGroup() {
                try {
                    await connection.invoke("JoinAdmin");
                } catch (error) {
                    const message = error && error.message ? error.message : "Unknown error";
                    addFeedItem(`Connected but failed to join admin notification group: ${message}`);
                }
            }

            connection.onreconnecting(() => setStatus(false));

            connection.onreconnected(async () => {
                setStatus(true);
                await joinAdminGroup();
            });

            connection.onclose((error) => {
                setStatus(false);
                if (error && error.message) {
                    addFeedItem(`SignalR connection closed: ${error.message}`);
                }
                scheduleReconnect();
            });

            async function connect() {
                if (connection.state !== signalR.HubConnectionState.Disconnected) {
                    return;
                }

                try {
                    await connection.start();
                    setStatus(true);
                    await joinAdminGroup();
                } catch (error) {
                    setStatus(false);
                    const message = error && error.message ? error.message : "Unknown error";
                    addFeedItem(`SignalR connect failed: ${message}`);
                    scheduleReconnect();
                }
            }

            connect();
        })();
    </script>
}
